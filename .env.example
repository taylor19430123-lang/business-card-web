HOST=0.0.0.0
PORT=3010
TRUST_PROXY=true
JSON_BODY_LIMIT=10mb
UPLOAD_FILE_SIZE_MB=20

# Default English template fonts
DEFAULT_REGULAR_FONT_PATH=assets/fonts/Poppins-Regular.ttf
DEFAULT_BOLD_FONT_PATH=assets/fonts/Poppins-Bold.ttf

# Allow low-code embedded pages to iframe this app
ALLOWED_FRAME_ANCESTORS='self' https://*.feishu.cn https://*.larksuite.com https://*.feishu-pre.cn

# Public base URL used when writing downloadable PDF links back to Bitable
PUBLIC_BASE_URL=https://your-public-domain.example.com

# Optional: defaults to BITABLE_APP_SECRET if left empty
PUBLIC_DOWNLOAD_SECRET=

# Feishu Bitable writeback integration
BITABLE_APP_ID=
BITABLE_APP_SECRET=
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
BITABLE_EMAIL_FIELD=企业邮箱
BITABLE_PDF_URL_FIELD=PDF链接
BITABLE_STATUS_FIELD=发送状态
BITABLE_STATUS_READY_VALUE=待发送
BITABLE_TEMPLATE_FIELD=名片模板
